const int N = 3e5 + 5, mod = 1e9 + 7;


vector<int> adj[N];

vector<int> euler; // store tour
int in[N], out[N]; // entry / exit time
int timer = 0;

void dfs(int node, int parent) {
    in[node] = timer++;
    euler.push_back(node);

    for (auto child: adj[node]) {
        if (child == parent) continue;
        dfs(child, node);

        // بعد ما نرجع للأب
        // euler.push_back(node);
    }

    out[node] = timer - 1;
}
